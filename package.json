{
  "name": "baby-tracker",
  "version": "3.0.0",
  "description": "Baby Tracker PWA — modular ES modules, IndexedDB, Firebase RTDB, Offline-first",
  "type": "module",
  "scripts": {
    "test:unit": "node src/sleep.test.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test": "npm run test:unit && npm run test:e2e",
    "serve": "npx serve . -p 5000"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "serve": "^14.2.3",
    "wait-on": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kujmaaan/Baby-Tracker.git"
  },
  "keywords": ["pwa", "baby", "tracker", "offline", "indexeddb"],
  "license": "MIT"
}
